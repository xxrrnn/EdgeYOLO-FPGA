  voltage_map (VDDPE, 0.99);
  voltage_map (VDDCE, 0.99);
  voltage_map (VSSE, 0.0);

  /* operating-conditions */
  operating_conditions(ffg_cbestt_0p99v_0p99v_m40c) {
    process      : 1;
    temperature  : -40;
    voltage      : 0.99;
    tree_type    : balanced_tree;
  }
  default_operating_conditions : ffg_cbestt_0p99v_0p99v_m40c;

  /* wire-loads */
  wire_load("sample") {
    resistance   : 1.6e-05;
    capacitance  : 0.0002;
    area         : 1.7;
    slope        : 500;
    fanout_length(1,500);
  }

