# ============================================
# 白名单策略: 默认忽略所有，只保留源文件和关键报告
# ============================================

# 忽略所有文件
*

# ============================================
# 保留: 脚本文件
# ============================================
!*.tcl
!*.py
!*.sh
!Makefile

# ============================================
# 保留: RTL 源码（仅 rtl/ 目录下）
# ============================================
!rtl/
!rtl/**/
!rtl/**/*.v
!rtl/**/*.sv
!rtl/**/*.vhd
!rtl/**/*.cpp
!rtl/**/*.h
!rtl/**/.gitignore

# ============================================
# 保留: 文档和配置
# ============================================
!*.md
!README*
!.gitignore
!.gitattributes

# ============================================
# 保留: Jupyter Notebook 和数据文件
# ============================================
!*.ipynb
!*.data

# ============================================
# 保留: XDC 约束文件（仅 xdc/ 目录下）
# ============================================
!xdc/
!xdc/**/
!xdc/**/*.xdc

# ============================================
# 保留: Build 目录中的 RPT 报告
# ============================================
!build/
!build/**/
!build/**/ImplOutputDir/
!build/**/ImplOutputDir/*.rpt
!build/**/SynOutputDir/
!build/**/SynOutputDir/*.rpt

# ============================================
# 保留: 顶层 scripts 目录和所有 tcl
# ============================================
!scripts/
!scripts/**/

# ============================================
# 保留: filelist（用于仿真）
# ============================================
!*.f

# ============================================
# 保留: gtkw 波形配置
# ============================================
!*.gtkw

# ============================================
# 忽略: Spyglass 生成文件
# ============================================
rtl/**/spyglass/
rtl/**/.project*
rtl/**/.design*
rtl/**/.CurrentSessionRunSummaryFiles

# ============================================
# 保留: 仿真测试目录
# ============================================
!tests/
!tests/**/
!tests/**/*.py
!tests/**/*.ipynb
!tests/**/*.sh

# ============================================
# 忽略: bd 目录所有内容（但保留 scripts 下的）
# ============================================
bd/
!scripts/**/bd/
!scripts/**/bd/**/*.tcl

# ============================================
# 忽略: Vivado 生成文件
# ============================================
.Xil/
*.jou
*.log
*.xpr
*.cache/
*.gen/
*.hw/
*.ip_user_files/
*.sim/
*.srcs/
*.runs/

# ============================================
# 忽略: Python 缓存
# ============================================
__pycache__/
*.pyc
.venv/
venv/

# ============================================
# 忽略: Jupyter 检查点
# ============================================
.ipynb_checkpoints/

# ============================================
# 再次忽略: 白名单中的误放行（须列在 !rtl/** 之后）
# ============================================
# 外部参考 RTL 树（内含独立 .git，勿入库）
rtl/ref/YOLOv11-RTL/
# VCS / DPI 在 csrc 下自动生成的头文件（勿提交）
rtl/**/csrc/rmapats.h
rtl/**/csrc/rmar.h
rtl/**/csrc/rmar0.h

# ============================================
# 忽略: Cursor IDE 文件
# ============================================
.codex
.cursor/
